---
import Layout from '../../layouts/Layout.astro';
import { operators } from '../../data/operators.js';

export function getStaticPaths() {
	return operators
		.filter((op) => op.isFounder && op.slug && op.photo && op.fullBio)
		.map((op) => ({
			params: { slug: op.slug },
			props: { operator: op },
		}));
}

const { operator } = Astro.props;
---

<Layout>

	{/* HERO */}
	<section class="bg-surface-alt py-16 md:py-20">
		<div class="mx-auto max-w-6xl px-6">
			<a href="/about" class="inline-flex items-center gap-2 text-sm font-medium text-brand-primary transition-colors hover:text-brand-secondary">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="19" y1="12" x2="5" y2="12" />
					<polyline points="12 19 5 12 12 5" />
				</svg>
				Back to the team
			</a>

			<div class="mt-8 grid grid-cols-1 gap-12 md:grid-cols-[2fr_3fr] md:items-start">
				<div class="overflow-hidden rounded-2xl border border-ink/10 bg-surface">
					<img
						src={operator.photo}
						alt={`${operator.name}, ${operator.role}`}
						class="aspect-square w-full object-cover object-top"
					/>
				</div>

				<div>
					<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
						{operator.role}
					</p>
					<h1 class="mt-4 font-display text-4xl font-semibold leading-[1.05] tracking-tight text-ink md:text-5xl lg:text-6xl">
						{operator.name}
					</h1>
					<ul class="mt-8 space-y-3">
						{operator.bullets.map((b) => (
							<li class="flex items-start gap-3 text-base text-ink-muted md:text-lg">
								<span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-primary" aria-hidden="true"></span>
								<span class="leading-snug">{b}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	{/* FULL BIO */}
	<section class="bg-surface py-20 md:py-28">
		<div class="mx-auto max-w-3xl px-6">
			<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
				About {operator.name.split(' ')[0]}
			</p>
			<h2 class="mt-4 font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
				The full story.
			</h2>
			<div class="mt-8 space-y-6 text-lg leading-relaxed text-ink">
				{operator.fullBio.map((p) => (
					<p>{p}</p>
				))}
			</div>
		</div>
	</section>

	{/* TESTIMONIALS */}
	{/* TODO: populate operator.testimonials with real client quotes */}
	<section class="bg-surface-alt py-20 md:py-28">
		<div class="mx-auto max-w-6xl px-6">
			<div class="reveal max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
					What Clients Say
				</p>
				<h2 class="mt-4 font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
					Operators {operator.name.split(' ')[0]} has worked with.
				</h2>
			</div>

			{operator.testimonials.length > 0 ? (
				<div class="reveal-stagger mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
					{operator.testimonials.map((t) => (
						<article class="flex h-full flex-col break-inside-avoid rounded-2xl border border-ink/10 bg-surface p-8">
							<div class="flex gap-1 text-brand-primary">
								{Array.from({ length: 5 }).map(() => (
									<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
										<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
									</svg>
								))}
							</div>
							<blockquote class="mt-6 flex-1 text-base leading-relaxed text-ink">
								"{t.quote}"
							</blockquote>
							<div class="mt-8 border-t border-ink/10 pt-6">
								<p class="font-display font-semibold text-ink">{t.author}</p>
								<p class="text-sm text-ink-muted">{t.title}</p>
							</div>
						</article>
					))}
				</div>
			) : (
				<div class="reveal-stagger mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
					{Array.from({ length: 3 }).map(() => (
						<div class="flex aspect-[4/3] flex-col items-center justify-center gap-3 rounded-2xl bg-gradient-to-br from-brand-primary/10 via-brand-accent/5 to-surface">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10 text-brand-primary/40" aria-hidden="true">
								<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
								<path d="M8 12a2 2 0 0 0 2-2V8H8" />
								<path d="M14 12a2 2 0 0 0 2-2V8h-2" />
							</svg>
							<p class="text-xs uppercase tracking-wider text-ink-muted/60">Testimonial coming soon</p>
						</div>
					))}
				</div>
			)}
		</div>
	</section>

	{/* VIDEO TESTIMONIALS */}
	{/* TODO: populate operator.videoTestimonials with real client video URLs */}
	<section class="bg-surface py-20 md:py-28">
		<div class="mx-auto max-w-6xl px-6">
			<div class="reveal max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
					Video Testimonials
				</p>
				<h2 class="mt-4 font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
					Hear it directly from clients.
				</h2>
			</div>

			{operator.videoTestimonials.length > 0 ? (
				<div class="reveal-stagger mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
					{operator.videoTestimonials.map((v) => (
						<div class="flex flex-col">
							<div class="aspect-video overflow-hidden rounded-2xl border border-ink/10 bg-ink/5">
								<iframe
									src={v.embedUrl}
									title={v.author ? `Video testimonial from ${v.author}` : 'Video testimonial'}
									class="h-full w-full"
									loading="lazy"
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
									allowfullscreen
								></iframe>
							</div>
							{(v.author || v.title) && (
								<div class="mt-4">
									{v.author && <p class="font-display font-semibold text-ink">{v.author}</p>}
									{v.title && <p class="text-sm text-ink-muted">{v.title}</p>}
								</div>
							)}
						</div>
					))}
				</div>
			) : (
				<div class="reveal-stagger mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
					{Array.from({ length: 3 }).map(() => (
						<div class="flex aspect-video flex-col items-center justify-center gap-3 rounded-2xl bg-gradient-to-br from-brand-primary/10 via-brand-accent/5 to-surface-alt">
							<div class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-primary/20">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7 text-brand-primary" aria-hidden="true">
									<polygon points="6 4 20 12 6 20 6 4" />
								</svg>
							</div>
							<p class="text-xs uppercase tracking-wider text-ink-muted/60">Video testimonial coming soon</p>
						</div>
					))}
				</div>
			)}
		</div>
	</section>

	{/* FINAL CTA */}
	<section class="bg-[#16122d] py-24 md:py-32">
		<div class="mx-auto max-w-4xl px-6 text-center">
			<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
				Want to Talk?
			</p>
			<h2 class="mt-6 font-display text-4xl font-bold leading-tight text-white md:text-5xl">
				Operators talk to operators.
			</h2>
			<p class="mx-auto mt-6 max-w-2xl text-lg text-white/70 md:text-xl">
				Book a 30-minute demo and you'll be on a working session with {operator.name.split(' ')[0]} or another founder. No SDR. No pitch.
			</p>
			<div class="mt-10 flex justify-center">
				<a
					href="/contact"
					class="inline-flex items-center justify-center rounded-full bg-brand-primary px-8 py-4 font-medium text-white transition-colors hover:bg-brand-secondary focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
				>
					Book a Demo
				</a>
			</div>
		</div>
	</section>

</Layout>
