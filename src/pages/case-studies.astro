---
import Layout from '../layouts/Layout.astro';

const aggregateStats = [
	{ target: 674, prefix: '', suffix: '', decimals: 0, label: 'Total Bookings Generated' },
	{ target: 319778, prefix: '$', suffix: '+', decimals: 0, label: 'Total Revenue Generated for Clients' },
	{ target: 14.86, prefix: '$', suffix: '', decimals: 2, label: 'Average Cost Per Lead' },
	{ target: 37278, prefix: '$', suffix: '', decimals: 0, label: 'Total Ad Spend' },
];

const caseStudies = [
	{ name: 'Ageless Aesthetics',         location: '',                duration: '45 Days',  offers: ['T-Shape Toning', 'T-Shape Facial'], bookings: 41, revenueTarget: 12000, revenueSuffix: '+', cpl: '$13.95', adSpend: '$1,925', image: '/case-studies/ageless-asthetics.png' },
	{ name: 'The Covery Wellness Spa',    location: 'Huntsville, AL',  duration: '120 Days', offers: ['T-Shape Toning'],                  bookings: 54, revenueTarget: 32230, revenueSuffix: '+', cpl: '$11.69', adSpend: '$2,888', image: '/case-studies/covery-huntsville.png' },
	{ name: 'The Covery Wellness Spa',    location: 'Fruitville, FL',  duration: '42 Days',  offers: ['T-Shape Toning'],                  bookings: 24, revenueTarget: 9000,  revenueSuffix: '+', cpl: '$11.69', adSpend: '$1,083', image: '/case-studies/covery-wellness-fruitville.png' },
	{ name: 'Vital Hydration',            location: '',                duration: '39 Days',  offers: ['T-Shape Toning', 'T-Shape Facial'], bookings: 56, revenueTarget: 18550, revenueSuffix: '+', cpl: '$9.17',  adSpend: '$2,240', image: '/case-studies/vital-hydration.png' },
	{ name: 'Body Essentials Hsv',        location: '',                duration: '30 Days',  offers: ['T-Shape Toning', 'T-Shape Facial'], bookings: 24, revenueTarget: 14515, revenueSuffix: '',  cpl: '$10.04', adSpend: '$1,045', image: '/case-studies/body-essentials-hsv.png' },
	{ name: 'Elite Aesthetics & Medical', location: '',                duration: '14 Days',  offers: ['T-Shape Toning', 'T-Shape Facial'], bookings: 56, revenueTarget: 31415, revenueSuffix: '+', cpl: '$3.04',  adSpend: '$684',   image: '/case-studies/elite-aesthetics.png' },
	{ name: 'Philly Wellness Center',     location: '',                duration: '14 Days',  offers: ['T-Shape Toning', 'T-Shape Facial'], bookings: 17, revenueTarget: 5200,  revenueSuffix: '+', cpl: '$13.06', adSpend: '$1,000', image: '/case-studies/philly-wellness-center.png' },
	{ name: 'Reclaim Health',             location: 'NC',              duration: '14 Days',  offers: ['T-Shape Toning', 'T-Shape Facial'], bookings: 15, revenueTarget: 14000, revenueSuffix: '+', cpl: '$14.26', adSpend: '$1,000', image: '/case-studies/reclaim-health.png' },
	{ name: 'Blush Body Studio',          location: '',                duration: '34 Days',  offers: ['T-Shape Toning', 'T-Shape Facial', 'CryoSlimming Toning'], bookings: 37,  revenueTarget: 22000, revenueSuffix: '+', cpl: '$14.72', adSpend: '$2,989', image: '/case-studies/body-blush-studio.png' },
	{ name: 'Argyle Cryo',                location: '',                duration: '31 Days',  offers: ['CryoSlimming Toning', 'CryoLift Facial'],                   bookings: 73,  revenueTarget: 56000, revenueSuffix: '+', cpl: '$19.98', adSpend: '$3,540', image: '/case-studies/argyle-cryo.png' },
	{ name: 'Texas Cryo Works',           location: '',                duration: '30 Days',  offers: ['CryoSlimming Toning', 'CryoLift Facial'],                   bookings: 41,  revenueTarget: 29743, revenueSuffix: '+', cpl: '$19.53', adSpend: '$3,340', image: '/case-studies/texas-cryoworks.png' },
	{ name: 'Midwest Wellness Lounge',    location: '',                duration: '5 Months', offers: ['CryoSlimming Toning', 'CryoLift Facial', 'T-Shape Combo'],  bookings: 236, revenueTarget: 75125, revenueSuffix: '+', cpl: '$18.01', adSpend: '$15,543', image: '/case-studies/midwest-cryo-lounge.png' },
];
---

<Layout>
	<div class="bg-[#010130]">

		{/* HERO */}
		<section class="relative overflow-hidden px-6 pb-16 pt-32 md:px-12 md:pt-40">
			<div class="orb orb-1" aria-hidden="true"></div>
			<div class="grid-overlay" aria-hidden="true"></div>

			<div class="relative z-10 mx-auto max-w-4xl text-center">
				<p class="reveal mb-5 inline-block bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text text-xs font-semibold uppercase tracking-[3px] text-transparent">
					Real clients. Real results.
				</p>

				<h1 class="reveal font-display text-[clamp(36px,5.5vw,72px)] font-bold leading-[1.05] tracking-tight text-white [transition-delay:150ms]">
					Results That Speak for Themselves
				</h1>

				<p class="reveal mx-auto mt-6 max-w-2xl text-base leading-[1.7] text-white/60 md:text-lg [transition-delay:300ms]">
					Trusted by 500+ aesthetic and wellness businesses across the US. Here's what's possible when you partner with Growth Now Media.
				</p>

				<div class="reveal mt-10 [transition-delay:450ms]">
					<a
						href="/contact"
						class="inline-flex w-full items-center justify-center rounded-full bg-brand-primary px-8 py-3.5 font-display text-[15px] font-semibold text-white shadow-[0_0_32px_rgba(138,26,255,0.35)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-brand-secondary hover:shadow-[0_8px_40px_rgba(138,26,255,0.5)] sm:w-auto"
					>
						Book a Demo
					</a>
				</div>
			</div>
		</section>

		{/* AGGREGATE STATS BAR */}
		<section class="border-y border-brand-primary/15 px-6 py-12 md:px-12 md:py-16">
			<div class="mx-auto grid max-w-6xl grid-cols-1 gap-y-10 gap-x-8 sm:grid-cols-2 md:grid-cols-4">
				{aggregateStats.map((stat) => (
					<div class="text-center">
						<p
							class="bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text font-display text-3xl font-bold leading-none text-transparent md:text-[40px]"
							data-count-target={stat.target}
							data-count-prefix={stat.prefix}
							data-count-suffix={stat.suffix}
							data-count-decimals={stat.decimals}
						>
							{stat.prefix}0{stat.suffix}
						</p>
						<p class="mt-3 text-xs font-medium uppercase tracking-[2px] text-white/60">
							{stat.label}
						</p>
					</div>
				))}
			</div>
		</section>

		{/* CASE STUDIES GRID */}
		<section class="px-6 py-24 md:px-12">
			<div class="mx-auto max-w-6xl">
				<h2 class="reveal mb-12 bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] tracking-tight text-transparent">
					Campaign Results
				</h2>

				<div class="reveal-stagger grid grid-cols-1 gap-6 md:grid-cols-2">
					{caseStudies.map((cs) => (
						<article class="group flex flex-col rounded-2xl border border-brand-primary/[0.12] bg-white/[0.03] p-6 transition-all duration-300 ease-out hover:-translate-y-1 hover:border-brand-accent/40 hover:shadow-[0_8px_40px_rgba(15,255,255,0.18)]">
							{/* Image with gradient placeholder fallback */}
							<div class="relative aspect-[16/10] overflow-hidden rounded-xl">
								<div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-primary/30 via-brand-secondary/25 to-brand-magenta/20 px-4 text-center">
									<span class="font-display text-base font-bold text-white/85 md:text-lg">
										{cs.name}
									</span>
								</div>
								<img
									src={cs.image}
									alt={cs.name}
									loading="lazy"
									class="absolute inset-0 h-full w-full object-cover"
									onerror="this.style.display='none'"
								/>
							</div>

							{/* Name + location */}
							<h3 class="mt-6 font-display text-2xl font-bold leading-tight text-white">
								{cs.name}
							</h3>
							{cs.location && (
								<p class="mt-1 text-sm text-white/60">{cs.location}</p>
							)}

							{/* 2x2 stats grid */}
							<div class="mt-5 grid grid-cols-2 gap-x-4 gap-y-4">
								<div>
									<p class="text-[10px] font-semibold uppercase tracking-[1.5px] text-white/50">Bookings</p>
									<p
										class="mt-1 bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text font-display text-3xl font-bold leading-none text-transparent"
										data-count-target={cs.bookings}
										data-count-prefix=""
										data-count-suffix=""
										data-count-decimals="0"
									>
										0
									</p>
								</div>
								<div>
									<p class="text-[10px] font-semibold uppercase tracking-[1.5px] text-white/50">Revenue</p>
									<p
										class="mt-1 bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text font-display text-3xl font-bold leading-none text-transparent"
										data-count-target={cs.revenueTarget}
										data-count-prefix="$"
										data-count-suffix={cs.revenueSuffix}
										data-count-decimals="0"
									>
										$0{cs.revenueSuffix}
									</p>
								</div>
								<div>
									<p class="text-[10px] font-semibold uppercase tracking-[1.5px] text-white/50">Cost Per Lead</p>
									<p class="mt-1 font-display text-xl font-bold leading-none text-white">{cs.cpl}</p>
								</div>
								<div>
									<p class="text-[10px] font-semibold uppercase tracking-[1.5px] text-white/50">Total Ad Spend</p>
									<p class="mt-1 font-display text-xl font-bold leading-none text-white">{cs.adSpend}</p>
								</div>
							</div>

							{/* Offer pills */}
							<div class="mt-5 flex flex-wrap gap-2">
								{cs.offers.map((offer) => (
									<span class="inline-flex items-center rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/85">
										{offer}
									</span>
								))}
							</div>

							{/* Duration */}
							<p class="mt-5 text-xs uppercase tracking-wider text-white/40">
								{cs.duration} campaign
							</p>
						</article>
					))}
				</div>
			</div>
		</section>

		{/* FEATURED LAUNCHES */}
		<section class="px-6 py-24 md:px-12">
			<div class="mx-auto max-w-6xl">
				<h2 class="reveal mb-12 font-display text-[clamp(32px,4vw,52px)] font-bold leading-[1.1] tracking-tight text-white">
					Record-Breaking Launches
				</h2>

				<div class="reveal-stagger grid grid-cols-1 gap-8 md:grid-cols-2">
					{/* Card 1 — Dolecheck */}
					<article class="flex flex-col overflow-hidden rounded-2xl border border-brand-primary/[0.12] bg-white/[0.03]">
						<div class="relative aspect-[16/10] overflow-hidden">
							<div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-primary/30 via-brand-secondary/25 to-brand-magenta/20 px-4 text-center">
								<span class="font-display text-lg font-bold text-white/85">
									Jessica &amp; Mark Dolecheck
								</span>
							</div>
							<img
								src="/case-studies/covery-lafayette.png"
								alt="Jessica and Mark Dolecheck"
								loading="lazy"
								class="absolute inset-0 h-full w-full object-cover"
								onerror="this.style.display='none'"
							/>
						</div>

						<div class="flex flex-1 flex-col p-8">
							<p class="font-display text-lg font-bold text-white">Jessica &amp; Mark Dolecheck</p>
							<p class="mt-1 text-sm text-white/60">Owners, The Covery — Lafayette</p>

							<p
								class="mt-6 bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text font-display text-5xl font-bold leading-none text-transparent md:text-6xl"
								data-count-target="80000"
								data-count-prefix="$"
								data-count-suffix="+"
								data-count-decimals="0"
							>
								$0+
							</p>
							<p class="mt-2 text-sm font-medium uppercase tracking-wider text-white/70">
								In just 8 days
							</p>

							<p class="mt-6 text-base leading-[1.7] text-white/70">
								Jessica and Mark have partnered with Growth Now Media for over a year. When they added the T-Shape 2 to their service menu, we built a step-by-step launch playbook around it. Eight days into the launch, they had collected over $80,000 in T-Shape package sales — and the bookings haven't stopped.
							</p>
						</div>
					</article>

					{/* Card 2 — Hayes */}
					<article class="flex flex-col overflow-hidden rounded-2xl border border-brand-primary/[0.12] bg-white/[0.03]">
						<div class="relative aspect-[16/10] overflow-hidden">
							<div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-primary/30 via-brand-secondary/25 to-brand-magenta/20 px-4 text-center">
								<span class="font-display text-lg font-bold text-white/85">
									Jason &amp; Anu Hayes
								</span>
							</div>
							<img
								src="/case-studies/covery-huntsville.png"
								alt="Jason and Anu Hayes"
								loading="lazy"
								class="absolute inset-0 h-full w-full object-cover"
								onerror="this.style.display='none'"
							/>
						</div>

						<div class="flex flex-1 flex-col p-8">
							{/* Gradient border badge */}
							<span class="inline-block w-fit rounded-full bg-gradient-to-r from-brand-primary to-brand-accent p-px">
								<span class="block rounded-full bg-[#010130] px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[1.5px] text-white">
									#1 T-Shape 2 Launch in the Country
								</span>
							</span>

							<p class="mt-4 font-display text-lg font-bold text-white">Jason &amp; Anu Hayes</p>
							<p class="mt-1 text-sm text-white/60">Owners, The Covery — Huntsville, AL</p>

							<p
								class="mt-6 bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text font-display text-5xl font-bold leading-none text-transparent md:text-6xl"
								data-count-target="52000"
								data-count-prefix="$"
								data-count-suffix="+"
								data-count-decimals="0"
							>
								$0+
							</p>
							<p class="mt-2 text-sm font-medium uppercase tracking-wider text-white/70">
								Launch weekend revenue
							</p>

							<p class="mt-6 text-base leading-[1.7] text-white/70">
								The Covery Wellness Spa launched T-Shape 2 with a high-impact event weekend featuring exclusive specials and educational materials. A targeted RSVP reactivation campaign drove 35+ pre-sale bookings with deposits. The launch event set a national record.
							</p>

							<blockquote class="mt-6 border-l-2 border-brand-accent pl-4 text-base italic leading-[1.6] text-white/85">
								"We had the number 1 T-Shape 2 launch in the country! We collected over $52,000 during the weekend."
								<footer class="mt-2 not-italic text-sm text-white/60">— Anu H., Owner</footer>
							</blockquote>
						</div>
					</article>
				</div>
			</div>
		</section>

		{/* FINAL CTA */}
		<section class="px-6 py-24 text-center md:px-12 md:py-32">
			<div class="reveal mx-auto max-w-3xl">
				<h2 class="font-display text-[clamp(36px,5vw,64px)] font-bold leading-[1.1] tracking-tight text-white">
					Ready to be the next case study?
				</h2>
				<p class="mx-auto mt-6 max-w-xl text-base leading-[1.7] text-white/65 md:text-lg">
					Book a free demo and we'll show you exactly how we'd grow your aesthetic or wellness business.
				</p>
				<div class="mt-10">
					<a
						href="/contact"
						class="cs-pulse-btn inline-flex w-full items-center justify-center rounded-full bg-brand-primary px-10 py-4 font-display text-base font-semibold text-white transition-all duration-300 ease-out hover:scale-105 hover:bg-brand-secondary sm:w-auto"
					>
						Book a Demo
					</a>
				</div>
				<p class="mt-8 text-sm text-white/50">
					Trusted by 500+ aesthetic and wellness businesses across the US
				</p>
			</div>
		</section>

	</div>

	<script>
		// Unified count-up observer for all [data-count-target] elements on the page.
		// Re-runs on every page-load so transitions wire a fresh observer to the new DOM.
		document.addEventListener('astro:page-load', () => {
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const counters = document.querySelectorAll('[data-count-target]');
			if (!counters.length) return;

			const formatNumber = (num: number, prefix: string, suffix: string, decimals: number) => {
				let str: string;
				if (decimals > 0) {
					str = num.toFixed(decimals);
				} else {
					str = Math.floor(num).toString();
				}
				const parts = str.split('.');
				parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
				str = parts.join('.');
				return `${prefix}${str}${suffix}`;
			};

			const animateCounter = (el: Element) => {
				const target = parseFloat(el.getAttribute('data-count-target') || '0');
				const prefix = el.getAttribute('data-count-prefix') || '';
				const suffix = el.getAttribute('data-count-suffix') || '';
				const decimals = parseInt(el.getAttribute('data-count-decimals') || '0', 10);

				if (reduceMotion) {
					el.textContent = formatNumber(target, prefix, suffix, decimals);
					return;
				}

				const duration = 2000;
				const start = performance.now();
				const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

				const tick = (now: number) => {
					const progress = Math.min((now - start) / duration, 1);
					const value = easeOutCubic(progress) * target;
					el.textContent = formatNumber(value, prefix, suffix, decimals);
					if (progress < 1) {
						requestAnimationFrame(tick);
					} else {
						el.textContent = formatNumber(target, prefix, suffix, decimals);
					}
				};
				requestAnimationFrame(tick);
			};

			const observer = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							animateCounter(entry.target);
							observer.unobserve(entry.target);
						}
					}
				},
				{ threshold: 0.3 }
			);
			counters.forEach((el) => observer.observe(el));
		});
	</script>

	<style>
		.cs-pulse-btn {
			animation: cs-cyan-pulse 2.4s cubic-bezier(0.16, 1, 0.3, 1) infinite;
		}

		@keyframes cs-cyan-pulse {
			0%, 100% {
				box-shadow: 0 0 0 0 rgba(15, 255, 255, 0.35), 0 0 28px rgba(138, 26, 255, 0.35);
			}
			50% {
				box-shadow: 0 0 0 12px rgba(15, 255, 255, 0), 0 0 48px rgba(15, 255, 255, 0.45);
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.cs-pulse-btn { animation: none; }
		}
	</style>
</Layout>
