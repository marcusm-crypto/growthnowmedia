---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

// TODO: confirm exact stat values with Marcus
const stats = [
	{ value: '500', superscript: '+', label: 'Locations growing' },
	{ value: '3', superscript: 'x', label: 'Average revenue lift' },
	{ value: '90', superscript: 'd', label: 'To see real results' },
	{ value: '#1', superscript: '', label: 'Growth system for aesthetic & wellness' },
];

// TODO: replace placeholder client names with real client logos
const logos = ['MedSpa Pro', 'Glow Aesthetics', 'Pure Wellness', 'Lumina Clinic', 'SkinFirst'];

const services = [
	{
		icon: '📈',
		title: 'Revenue Growth',
		body: 'Data-driven campaigns built specifically for aesthetic and wellness businesses. No fluff — just more booked appointments.',
	},
	{
		icon: '🎯',
		title: 'Client Acquisition',
		body: 'Attract the right clients who are ready to book and spend. Not just followers — real paying customers.',
	},
	{
		icon: '⚡',
		title: 'Done-For-You System',
		body: 'We build and run the Growth Now System™ for you. You focus on clients. We handle the growth.',
	},
];
---

<Layout>
	<div class="bg-[#0a0812]">

		<Hero />

		{/* STATS STRIP */}
		<section class="reveal flex justify-center gap-0 border-y border-brand-primary/15 px-6 py-10 md:px-12">
			{stats.map((s, i) => (
				<div class={`relative flex-1 max-w-[220px] px-4 text-center md:px-10 ${i < stats.length - 1 ? 'after:absolute after:right-0 after:top-1/2 after:h-10 after:w-px after:-translate-y-1/2 after:bg-brand-primary/20' : ''}`}>
					<div class="font-display text-[40px] font-extrabold leading-none tracking-[-1px] text-white">
						{s.value}<span class="text-brand-accent">{s.superscript}</span>
					</div>
					<div class="mt-1.5 text-[13px] font-normal text-white/60">{s.label}</div>
				</div>
			))}
		</section>

		{/* LOGOS */}
		<section class="reveal px-6 py-16 text-center md:px-12">
			<p class="mb-8 text-xs font-medium uppercase tracking-[2px] text-white/60">
				Trusted by businesses across the US
			</p>
			<div class="flex flex-wrap items-center justify-center gap-12">
				{logos.map((name) => (
					<div class="rounded-full border border-white/[0.08] bg-white/[0.04] px-6 py-2.5 font-display text-sm font-semibold tracking-[0.5px] text-white/30 transition-all hover:border-brand-primary/30 hover:text-white/60">
						{name}
					</div>
				))}
			</div>
		</section>

		{/* SERVICES */}
		<section id="services" class="px-6 py-24 md:px-12">
			<p class="mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
				What we do
			</p>
			<h2 class="reveal mb-14 max-w-xl font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
				The system that fills your calendar
			</h2>
			<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
				{services.map((svc) => (
					<article class="reveal group relative overflow-hidden rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-9 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/35 hover:bg-brand-primary/[0.06]">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(110,69,233,0.08)_0%,transparent_60%)] opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true"></div>
						<div class="relative">
							<div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl border border-brand-primary/25 bg-brand-primary/15 text-[22px]" aria-hidden="true">
								{svc.icon}
							</div>
							<h3 class="mb-2.5 font-display text-lg font-bold tracking-[-0.3px] text-white">{svc.title}</h3>
							<p class="text-sm leading-[1.7] text-white/60">{svc.body}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		{/* CTA CARD */}
		<section class="reveal mx-6 mb-24 overflow-hidden rounded-[28px] bg-gradient-to-br from-brand-secondary to-brand-primary p-20 text-center md:mx-12">
			<div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:40px_40px]" aria-hidden="true"></div>
			<div class="relative">
				<h2 class="mb-4 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-tight tracking-[-1.5px] text-white">
					Ready to grow your business?
				</h2>
				<p class="mb-10 text-base text-white/70">
					Book a free demo and we'll show you exactly how it works for your business.
				</p>
				<a
					href="/contact"
					class="inline-block rounded-full bg-white px-9 py-3.5 font-display text-[15px] font-bold text-brand-secondary transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(0,0,0,0.3)]"
				>
					Book a Demo →
				</a>
			</div>
		</section>

	</div>
</Layout>
