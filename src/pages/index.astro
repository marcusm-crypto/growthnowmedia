---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LogoWall from '../components/LogoWall.astro';
import TwoPaths from '../components/TwoPaths.astro';
import Testimonials from '../components/Testimonials.astro';
import HowWeWork from '../components/HowWeWork.astro';

// TODO: confirm exact stat values with Marcus
const stats = [
	{ target: 500, prefix: '', superscript: '+', label: 'Locations growing' },
	{ target: 3, prefix: '', superscript: 'x', label: 'Average revenue lift' },
	{ target: 48, prefix: '', superscript: 'hr', label: 'To your first booking' },
	{ target: 1, prefix: '#', superscript: '', label: 'Growth system for aesthetic & wellness' },
];

const services = [
	{
		icon: '📈',
		title: 'Revenue Growth',
		body: 'High-tech, high-touch campaigns powered by AI and real human strategy — built specifically for aesthetic and wellness businesses. More booked appointments, less guesswork.',
	},
	{
		icon: '🎯',
		title: 'Client Acquisition',
		body: 'We combine AI-driven targeting with hands-on expertise to attract clients who are ready to book and spend — not just browse.',
	},
	{
		icon: '⚡',
		title: 'Done-For-You System',
		body: 'We leverage AI and human expertise to build and run the Growth Now Method™ for you. You focus on delivering results. We handle everything else.',
	},
];
---

<Layout>
	<div class="bg-[#010130]">

		<Hero />

		{/* STATS STRIP */}
		<section
			data-stats-row
			class="reveal flex justify-center gap-0 border-y border-brand-primary/15 px-6 py-10 md:px-12"
		>
			{stats.map((s, i) => (
				<div class={`relative flex-1 max-w-[220px] px-4 text-center md:px-10 ${i < stats.length - 1 ? 'after:absolute after:right-0 after:top-1/2 after:h-10 after:w-px after:-translate-y-1/2 after:bg-brand-primary/20' : ''}`}>
					<div class="bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text font-display text-[40px] font-extrabold leading-none tracking-[-1px] text-transparent">
						<span data-count-target={s.target} data-count-prefix={s.prefix}>{s.prefix}0</span><span>{s.superscript}</span>
					</div>
					<div class="mt-1.5 text-[13px] font-normal text-white/60">{s.label}</div>
				</div>
			))}
		</section>

		<LogoWall />

		{/* OPERATOR ADVANTAGE */}
		<section class="px-6 py-24 md:px-12">
			<div class="mx-auto max-w-6xl">
				<div class="reveal mb-16 max-w-3xl">
					<p class="mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
						The Operator Advantage
					</p>
					<h2 class="mb-6 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
						We Don't Generalize.<br/>We Specialize.
					</h2>
					<p class="text-lg leading-[1.8] text-white/60">
						Most agencies serve everyone. We serve one industry — and we've spent years going deeper than anyone else in it. Growth Now Media works exclusively with med spas, wellness clinics, and aesthetic brands. We've partnered with 500+ of the top aesthetic and wellness businesses in America — not because we market well, but because we understand the business from the inside out. We've owned the locations, hired the providers, run the campaigns, and felt the pressure of a slow week. That operator experience is what separates us from every other agency in this space.
					</p>
				</div>

				<div class="reveal-stagger grid grid-cols-1 gap-6 md:grid-cols-3">
					<article class="group relative overflow-hidden rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-9 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/35 hover:bg-brand-primary/[0.06]">
						<div class="mb-4 text-4xl">🏆</div>
						<h3 class="mb-3 font-display text-xl font-bold tracking-[-0.3px] text-white">
							500+ Top Brands
						</h3>
						<p class="text-sm leading-[1.7] text-white/60">
							Trusted by the most recognized names in the aesthetic and wellness industry across America.
						</p>
					</article>

					<article class="group relative overflow-hidden rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-9 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/35 hover:bg-brand-primary/[0.06]">
						<div class="mb-4 text-4xl">🎯</div>
						<h3 class="mb-3 font-display text-xl font-bold tracking-[-0.3px] text-white">
							One Industry. Deep Expertise.
						</h3>
						<p class="text-sm leading-[1.7] text-white/60">
							We know your business because we've lived it — as owners, operators, and growth strategists inside the industry.
						</p>
					</article>

					<article class="group relative overflow-hidden rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-9 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/35 hover:bg-brand-primary/[0.06]">
						<div class="mb-4 text-4xl">📈</div>
						<h3 class="mb-3 font-display text-xl font-bold tracking-[-0.3px] text-white">
							Built to Fill Calendars
						</h3>
						<p class="text-sm leading-[1.7] text-white/60">
							Every strategy we run is designed to drive real bookings and measurable revenue — not vanity metrics.
						</p>
					</article>
				</div>

				<div class="reveal mt-12">
					<a
						href="#services"
						class="group inline-flex items-center gap-2 font-display text-[15px] font-semibold text-brand-accent transition-colors hover:text-white"
					>
						See How It Works
						<span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</section>

		<TwoPaths />

		{/* SERVICES */}
		<section id="services" class="px-6 py-24 md:px-12">
			<p class="mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
				What we do
			</p>
			<h2 class="reveal mb-14 max-w-xl font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
				The system that fills your calendar
			</h2>
			<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
				{services.map((svc) => (
					<article class="reveal group relative overflow-hidden rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-9 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/35 hover:bg-brand-primary/[0.06]">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(138, 26, 255,0.08)_0%,transparent_60%)] opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true"></div>
						<div class="relative">
							<div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl border border-brand-primary/25 bg-brand-primary/15 text-[22px]" aria-hidden="true">
								{svc.icon}
							</div>
							<h3 class="mb-2.5 font-display text-lg font-bold tracking-[-0.3px] text-white">{svc.title}</h3>
							<p class="text-sm leading-[1.7] text-white/60">{svc.body}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<Testimonials page="homepage" />

		<div class="reveal flex justify-center px-6 pb-12 md:px-12">
			<a
				href="/case-studies"
				class="group inline-flex items-center gap-2 font-display text-sm font-semibold text-brand-accent transition-colors hover:text-white"
			>
				See full case studies
				<span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
			</a>
		</div>

		<HowWeWork />

		{/* CTA CARD */}
		<section class="reveal mx-6 mb-24 overflow-hidden rounded-[28px] bg-gradient-to-br from-brand-secondary to-brand-primary p-20 text-center md:mx-12">
			<div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:40px_40px]" aria-hidden="true"></div>
			<div class="relative">
				<h2 class="reveal mb-4 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-tight tracking-[-1.5px] text-white">
					Ready to grow your business?
				</h2>
				<p class="reveal mb-10 text-base text-white/70 [transition-delay:100ms]">
					Book a free demo and we'll show you exactly how it works for your business.
				</p>
				<a
					href="/contact"
					class="reveal inline-block rounded-full bg-white px-9 py-3.5 font-display text-[15px] font-bold text-brand-secondary transition-all [transition-delay:200ms] hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(0,0,0,0.3)]"
				>
					Book a Demo →
				</a>
			</div>
		</section>

	</div>

	<script>
		// Count-up animation for the Stats strip — fires once when the row enters view.
		// Re-runs on every page-load (initial + post-transition) so a fresh observer
		// is wired up to the current page's DOM.
		document.addEventListener('astro:page-load', () => {
			const statsRow = document.querySelector('[data-stats-row]');
			if (!statsRow) return;

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const counters = statsRow.querySelectorAll('[data-count-target]');
			const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

			const animate = (el: Element, target: number, prefix: string) => {
				if (reduceMotion) {
					el.textContent = `${prefix}${target}`;
					return;
				}
				const duration = 1800;
				const start = performance.now();
				const tick = (now: number) => {
					const elapsed = now - start;
					const progress = Math.min(elapsed / duration, 1);
					const value = Math.floor(easeOutCubic(progress) * target);
					el.textContent = `${prefix}${value}`;
					if (progress < 1) requestAnimationFrame(tick);
					else el.textContent = `${prefix}${target}`;
				};
				requestAnimationFrame(tick);
			};

			const observer = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							counters.forEach((el) => {
								const target = parseInt(el.getAttribute('data-count-target') || '0', 10);
								const prefix = el.getAttribute('data-count-prefix') || '';
								animate(el, target, prefix);
							});
							observer.unobserve(statsRow);
						}
					}
				},
				{ threshold: 0.3 }
			);
			observer.observe(statsRow);
		});
	</script>
</Layout>
