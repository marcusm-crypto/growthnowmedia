---
import Layout from '../../layouts/Layout.astro';

const expectations = [
	{
		title: '30 minutes, no pitch',
		body: "We map your current marketing stack, KPIs, and growth ceiling — then tell you what we'd install. If we're not a fit, we'll say so.",
	},
	{
		title: 'You leave with a recommendation',
		body: 'Even if you never work with us, you walk away with a clear assessment of where you are and what would move the number.',
	},
	{
		title: 'Direct line to the founders',
		body: 'You talk to the operators who built and run the system. Not an SDR. Not a junior strategist.',
	},
];
---

<Layout>

	{/* 1. HERO */}
	<section class="bg-surface py-16 md:py-20">
		<div class="mx-auto max-w-3xl px-6 text-center">
			<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
				Book a Demo
			</p>
			<h1 class="mt-6 font-display text-4xl font-semibold leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
				Pick a time. We'll be there.
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-muted md:text-xl">
				30-minute discovery demo with the operators who run the Growth Now Method™ across 75+ wellness brands. No pitch — just a working session on what we'd build for you.
			</p>
		</div>
	</section>

	{/* 2. CALENDAR EMBED */}
	<section class="bg-surface pb-20 md:pb-28">
		<div class="mx-auto max-w-4xl px-6">
			<div class="overflow-visible rounded-2xl border border-ink/10 bg-surface-alt p-2 md:p-4">
				<iframe
					src="https://api.leadconnectorhq.com/widget/booking/9iTvJVPLykAov9hRXTnD"
					title="Book a discovery demo with Growth Now Media"
					id="6I7xkjjSjBi7FU18Xwhu_1777957348197"
					scrolling="no"
					class="block w-full"
					style="min-height: 900px; border: none; overflow: hidden;"
				></iframe>
			</div>
			<script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>
		</div>
	</section>

	{/* 3. WHAT TO EXPECT */}
	<section class="bg-surface-alt py-20 md:py-28">
		<div class="mx-auto max-w-6xl px-6">
			<div class="reveal max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
					What to Expect
				</p>
				<h2 class="mt-4 font-display text-3xl font-semibold leading-tight text-ink md:text-5xl">
					A working session, not a sales call.
				</h2>
			</div>

			<div class="reveal-stagger mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
				{expectations.map((item, i) => (
					<article class="card flex h-full flex-col break-inside-avoid rounded-2xl p-8">
						<p class="font-display text-4xl font-bold text-brand-primary/40">
							{String(i + 1).padStart(2, '0')}
						</p>
						<div class="mt-4 h-px w-12 bg-ink/10"></div>
						<h3 class="mt-4 font-display text-lg font-semibold leading-snug text-ink">
							{item.title}
						</h3>
						<p class="mt-3 text-base leading-relaxed text-ink-muted">{item.body}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	{/* 4. ALTERNATIVE CONTACT */}
	<section class="bg-surface py-20 md:py-28">
		<div class="mx-auto max-w-3xl px-6 text-center">
			<p class="text-sm font-semibold uppercase tracking-wider text-brand-primary">
				Prefer Email?
			</p>
			<h2 class="mt-4 font-display text-2xl font-semibold leading-tight text-ink md:text-3xl">
				Reach us directly.
			</h2>
			<p class="mt-4 text-base text-ink-muted">
				If you'd rather send a note before booking, or you have a specific question, we read every message.
			</p>
			<div class="mt-8 flex flex-col items-center justify-center gap-2 sm:flex-row sm:gap-8">
				<a
					href="mailto:info@growthnowmedia.com"
					class="font-display text-lg font-semibold text-brand-primary hover:underline"
				>
					info@growthnowmedia.com
				</a>
				<span class="hidden text-ink-muted sm:inline" aria-hidden="true">·</span>
				<a
					href="tel:+16195144169"
					class="font-display text-lg font-semibold text-brand-primary hover:underline"
				>
					619-514-4169
				</a>
			</div>
			<p class="mt-6 text-sm text-ink-muted">
				Limited seats per quarter. We respond within 48 hours.
			</p>
		</div>
	</section>

</Layout>
