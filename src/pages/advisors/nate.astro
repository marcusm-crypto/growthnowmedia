---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import { operators } from '../../data/operators.js';
import TestimonialLightbox from '../../components/TestimonialLightbox.astro';

const advisor = operators.find((op) => op.slug === 'nate-fennell')!;
const firstName = advisor.name.split(' ')[0];

// Auto-detect testimonials from /public/testimonials/nate/<slug>/{video.mp4, cover.png}.
// Frontmatter runs at build time, so node:fs is safe.
const advisorDir = path.join(process.cwd(), 'public/testimonials/nate');
const testimonials = fs.existsSync(advisorDir)
	? fs
			.readdirSync(advisorDir, { withFileTypes: true })
			.filter((entry) => entry.isDirectory())
			.map((entry) => entry.name)
			.filter((slug) =>
				fs.existsSync(path.join(advisorDir, slug, 'video.mp4')),
			)
			.map((slug) => ({
				slug,
				videoUrl: `/testimonials/nate/${slug}/video.mp4`,
				thumbnailUrl: fs.existsSync(path.join(advisorDir, slug, 'cover.png'))
					? `/testimonials/nate/${slug}/cover.png`
					: undefined,
			}))
	: [];
---

<Layout>
	<div class="bg-[#010130]">

		{/* HERO */}
		<section class="relative overflow-hidden px-6 pb-16 pt-32 md:px-12 md:pt-40">
			<div class="orb orb-1" aria-hidden="true"></div>
			<div class="grid-overlay" aria-hidden="true"></div>

			<div class="relative z-10 mx-auto max-w-4xl text-center">
				<p class="reveal mb-5 inline-block bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text text-xs font-semibold uppercase tracking-[3px] text-transparent">
					{advisor.role}
				</p>

				<h1 class="reveal font-display text-[clamp(36px,5.5vw,72px)] font-bold leading-[1.05] tracking-tight text-white [transition-delay:150ms]">
					{advisor.name}
				</h1>

				<p class="reveal mx-auto mt-6 max-w-2xl text-base leading-[1.7] text-white/60 md:text-lg [transition-delay:300ms]">
					{advisor.bullets.join(' · ')}
				</p>

				<div class="reveal mt-10 [transition-delay:450ms]">
					<a
						href="/contact"
						class="inline-flex w-full items-center justify-center rounded-full bg-brand-primary px-8 py-3.5 font-display text-[15px] font-semibold text-white shadow-[0_0_32px_rgba(138,26,255,0.35)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-brand-secondary hover:shadow-[0_8px_40px_rgba(138,26,255,0.5)] sm:w-auto"
					>
						Book a Call with {firstName}
					</a>
				</div>
			</div>
		</section>

		{/* CLIENT TESTIMONIALS */}
		<section class="px-6 py-20 md:px-12 md:py-28">
			<div class="mx-auto max-w-6xl">
				<h2 class="reveal mx-auto max-w-3xl bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-center font-display text-[clamp(28px,3.5vw,44px)] font-bold leading-[1.15] tracking-tight text-transparent">
					What {firstName}'s Clients Say
				</h2>

				{testimonials.length > 0 ? (
					<div class="reveal-stagger mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
						{testimonials.map((t, i) => (
							<button
								type="button"
								class="group flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-6 text-left transition-all duration-300 ease-out hover:-translate-y-1 hover:border-brand-accent/40 hover:shadow-[0_8px_40px_rgba(15,255,255,0.18)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-[#010130]"
								data-testimonial-trigger
								data-testimonial-index={i}
								aria-label={`Play client testimonial ${i + 1}`}
							>
								<div class="relative aspect-[9/16] overflow-hidden rounded-xl bg-black">
									{t.thumbnailUrl ? (
										<img
											src={t.thumbnailUrl}
											alt=""
											loading="lazy"
											class="h-full w-full object-cover"
										/>
									) : (
										<div class="absolute inset-0 bg-gradient-to-br from-brand-primary/30 via-brand-secondary/20 to-brand-magenta/15" aria-hidden="true"></div>
									)}
									<span
										class="pointer-events-none absolute inset-0 m-auto flex h-16 w-16 items-center justify-center rounded-full bg-white/85 shadow-[0_4px_16px_rgba(0,0,0,0.3)] transition-all duration-300 group-hover:bg-white motion-safe:group-hover:scale-[1.15] sm:h-[72px] sm:w-[72px]"
										aria-hidden="true"
									>
										<svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-7 w-7 text-brand-secondary">
											<polygon points="6 4 20 12 6 20 6 4" />
										</svg>
									</span>
								</div>
							</button>
						))}
					</div>
				) : (
					<p class="reveal mt-8 text-center text-base text-white/55">
						More testimonials coming soon.
					</p>
				)}
			</div>
		</section>

		{/* BIO */}
		<section class="px-6 py-20 md:px-12 md:py-28">
			<div class="mx-auto max-w-3xl">
				<p class="reveal text-sm font-semibold uppercase tracking-wider text-brand-accent">
					About {firstName}
				</p>
				<h2 class="reveal mt-4 font-display text-[clamp(28px,3.5vw,44px)] font-bold leading-tight text-white [transition-delay:100ms]">
					The full story.
				</h2>
				<div class="reveal mt-10 space-y-6 text-lg leading-[1.7] text-white/75 [transition-delay:200ms]">
					{advisor.fullBio.map((para) => (
						<p>{para}</p>
					))}
				</div>
			</div>
		</section>

		{/* FINAL CTA */}
		<section class="px-6 py-24 text-center md:px-12 md:py-32">
			<div class="reveal mx-auto max-w-3xl">
				<h2 class="font-display text-[clamp(36px,5vw,64px)] font-bold leading-[1.1] tracking-tight text-white">
					Want to work with {firstName}?
				</h2>
				<div class="mt-10">
					<a
						href="/contact"
						class="cs-pulse-btn inline-flex w-full items-center justify-center rounded-full bg-brand-primary px-10 py-4 font-display text-base font-semibold text-white transition-all duration-300 ease-out hover:scale-105 hover:bg-brand-secondary hover:shadow-[0_8px_40px_rgba(15,255,255,0.35)] sm:w-auto"
					>
						Book a Demo
					</a>
				</div>
			</div>
		</section>

	</div>

	<TestimonialLightbox testimonials={testimonials} />
</Layout>
