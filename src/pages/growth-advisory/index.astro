---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import TestimonialLightbox from '../../components/TestimonialLightbox.astro';

// Auto-detect video testimonials from /public/testimonials/nate/<slug>/{video.mp4, cover.png}.
// Same convention as /advisors/nate.astro — Nate is the lead advisor on this page.
const videoTestimonialsDir = path.join(process.cwd(), 'public/testimonials/nate');
const videoTestimonials = fs.existsSync(videoTestimonialsDir)
        ? fs
                .readdirSync(videoTestimonialsDir, { withFileTypes: true })
                .filter((entry) => entry.isDirectory())
                .map((entry) => entry.name)
                .filter((slug) =>
                        fs.existsSync(path.join(videoTestimonialsDir, slug, 'video.mp4')),
                )
                .map((slug) => ({
                        slug,
                        videoUrl: `/testimonials/nate/${slug}/video.mp4`,
                        thumbnailUrl: fs.existsSync(path.join(videoTestimonialsDir, slug, 'cover.png'))
                                ? `/testimonials/nate/${slug}/cover.png`
                                : undefined,
                }))
        : [];

const twoPathCards = [
        {
                icon: '🏢',
                tag: 'Franchise Buyer Advisory',
                body: 'Thinking about buying a franchise? Get unbiased guidance from an operator who has opened 30+ locations across multiple brands. We help you evaluate opportunities, review FDDs, and make a decision that actually fits your life and capital.',
                cta: 'Book a Franchise Strategy Call',
                href: '/contact',
        },
        {
                icon: '📈',
                tag: 'Growth & Marketing Advisory',
                body: 'Already operating a clinic, med spa, or wellness business? We help you scale revenue, fill your calendar, and build the systems that turn a single location into a scalable asset.',
                cta: 'Book a Growth Strategy Call',
                href: '/contact',
        },
];

const whoThisIsFor = [
        'Exploring franchise ownership but unsure where to start',
        'Comparing multiple brands and want unbiased guidance',
        'Concerned about fees, FDDs, and real-world economics',
        'Looking for a business that fits your lifestyle and income goals',
        'Already operating and ready to scale revenue systematically',
        'Deploying capital into the aesthetic and wellness space',
];

const whoThisIsNotFor = [
        'Looking for a get-rich-quick opportunity',
        'Already committed to a specific brand and just need a sales rep',
        'Unwilling to do proper diligence before investing',
];

const howWeHelp = [
        {
                title: 'Smart Franchise Selection',
                body: 'We vet franchise brands, business models, and markets — aligning opportunities with your goals, capital, and risk tolerance.',
        },
        {
                title: 'Clear Due Diligence',
                body: 'We walk you through FDDs, fees, financials, and red flags so you understand exactly what you are signing up for before you commit.',
        },
        {
                title: 'End-to-End Support',
                body: 'From early conversations and culture fit to site selection and launch, we stay involved well beyond introductions.',
        },
        {
                title: 'Sales & Marketing Systems',
                body: 'With real operator experience across hundreds of locations, we help you build practical revenue and marketing systems — not theory.',
        },
        {
                title: 'Long-Term Advisory Relationship',
                body: 'We are not one-time brokers. Our focus is helping you avoid costly mistakes and build a business that fits your life and income goals.',
        },
];

const differentiators = [
        'We have opened and operated 30+ locations across multiple brands — not just made introductions',
        'Our guidance goes beyond brand matching into real-world execution and operations',
        'We focus on fit and long-term sustainability, not pushing a deal to close',
        'Our role is advisory — brands handle their own sales process',
];

const trustStats = [
        { value: '8-Figure', label: 'Combined Founder Exits' },
        { value: '500+', label: 'Locations Launched & Scaled' },
        { value: '$8.5M+', label: 'Ad Spend Managed' },
        { value: '35+ Yrs', label: 'Combined Operator Experience' },
];

const testimonials = [
        {
                name: 'Amy Dickerson',
                title: 'Hydrate IV Bar Partner',
                quote: 'The guidance we received was unlike anything we had experienced with traditional franchise consultants. Real operator insight, zero pressure.',
        },
        {
                name: 'Aaron Archer',
                title: 'Hydrate IV Bar Owner, Atlanta',
                quote: 'Having someone in our corner who had actually opened locations across multiple brands made all the difference. We avoided mistakes we did not even know we were about to make.',
        },
        {
                name: 'Dr. Brian Bell',
                title: 'Wellness Physician',
                quote: 'I came in as a physician with no operations background. The advisory process gave me clarity, confidence, and a clear path forward.',
        },
];

const advisors = [
        {
                name: 'Nate Fennell',
                title: 'Co-Founder & Chief Operator',
                href: '/advisors/nate',
                photo: '/team/nate-fennell.jpg',
                bio: 'Nate is an entrepreneur, growth strategist, and franchise advisor with more than two decades of experience building and scaling businesses in the wellness, fitness, and longevity sectors. He has founded, grown, and helped lead multiple 7- and 8-figure businesses, opening 30+ locations across several brands. Having operated on both the franchisor and franchisee side, Nate brings a rare blend of operator insight and strategic advisory experience.',
        },
        {
                name: 'Andrew Sousa',
                title: 'Co-Founder & Head of Growth',
                href: '/advisors/andrew',
                photo: '/team/andrew-sousa.jpg',
                bio: 'Andrew is a growth operator and marketing strategist who has helped scale aesthetic and wellness businesses across the country. His expertise spans paid acquisition, revenue systems, and go-to-market strategy — built from years of hands-on work inside the businesses, not from the outside looking in.',
        },
];

const pathSteps = [
        {
                title: 'Schedule a Strategy Call',
                body: 'Book a free 30-minute call. No obligation, no sales pressure. We discuss your goals, budget, and whether our advisory makes sense for your situation.',
        },
        {
                title: 'Get a Clear Recommendation',
                body: 'We map your market, capital, timeline, and goals. You leave with a clear recommendation — even if we conclude we are not the right fit.',
        },
        {
                title: 'Build With Operator Support',
                body: 'If we move forward together, our team goes to work alongside you — from brand and site selection through launch and beyond.',
        },
        {
                title: 'Ongoing Advisory Access',
                body: 'We stay involved through your first 90 days and beyond, coaching you through real decisions with the experience of operators who have done it.',
        },
];

const faqItems = [
        {
                q: 'How is this different from a traditional franchise broker?',
                a: 'Traditional brokers match buyers to brands and earn a commission from the franchisor. We are operators first — we have opened and run 30+ locations ourselves. Our guidance covers real-world execution, not just introductions.',
        },
        {
                q: 'Do you work with franchisees and franchisors?',
                a: 'Yes. We work with buyers evaluating franchise opportunities, existing franchisees looking to scale, and franchisors building their growth systems. Our experience on both sides of the table gives us a perspective most advisors do not have.',
        },
        {
                q: 'What does the advisory cost?',
                a: 'That depends on the scope of engagement. The first call is always free. We discuss specific advisory arrangements after we understand your goals and situation.',
        },
        {
                q: 'How fast can we move?',
                a: 'First call is available within 48 hours of booking. From there, the pace depends on your timeline, capital readiness, and the complexity of the opportunity you are evaluating.',
        },
        {
                q: 'Do you guarantee results?',
                a: 'No serious operator does. What we can show you is a track record across 500+ aesthetic and wellness locations. We are selective because real advisory does not scale infinitely — and we win when our clients win.',
        },
];
---

<Layout>
        <div class="bg-[#010130]">

                {/* HERO */}
                <section class="relative overflow-hidden px-6 pb-20 pt-32 text-center md:px-12 md:pt-40">
                        <div class="orb orb-1" aria-hidden="true"></div>
                        <div class="orb orb-2" aria-hidden="true"></div>
                        <div class="grid-overlay" aria-hidden="true"></div>

                        <div class="relative z-10 mx-auto max-w-4xl">
                                <p class="reveal mb-5 inline-block bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text text-xs font-semibold uppercase tracking-[3px] text-transparent">
                                        Growth Now Advisor Program™
                                </p>
                                <h1 class="reveal font-display text-[clamp(36px,5.5vw,72px)] font-bold leading-[1.05] tracking-tight text-white [transition-delay:150ms]">
                                        Thinking About Your Next Move?<br/>Start With Clarity.
                                </h1>
                                <p class="reveal mx-auto mt-6 max-w-2xl text-lg leading-[1.7] text-white/60 [transition-delay:300ms]">
                                        Whether you are evaluating a franchise, launching your own clinic, or scaling an existing business — we offer advisor-led guidance backed by real operator experience. No sales pressure. No generic playbooks.
                                </p>
                                <div class="reveal mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row [transition-delay:450ms]">
                                        <a
                                                href="/contact"
                                                class="inline-flex items-center justify-center rounded-full bg-brand-primary px-8 py-3.5 font-display text-[15px] font-semibold text-white shadow-[0_0_32px_rgba(138,26,255,0.35)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-secondary"
                                        >
                                                Book a Strategy Call
                                        </a>
                                        <a
                                                href="#how-we-help"
                                                class="group inline-flex items-center gap-2 font-display text-[15px] font-medium text-white/70 transition hover:text-white"
                                        >
                                                See how it works
                                                <span class="flex h-8 w-8 items-center justify-center rounded-full border border-white/20 text-sm transition group-hover:border-white/40">→</span>
                                        </a>
                                </div>
                                <p class="mt-6 text-sm text-white/40">
                                        30+ locations opened · Multi-brand experience · Independent guidance
                                </p>
                        </div>
                </section>

                {/* STATS STRIP */}
                <section class="border-y border-brand-primary/15 px-6 py-10 md:px-12">
                        <div class="mx-auto flex max-w-5xl flex-wrap justify-center gap-0">
                                {trustStats.map((stat, i) => (
                                        <div class={`relative px-8 py-4 text-center md:px-12 ${i < trustStats.length - 1 ? "after:absolute after:right-0 after:top-1/2 after:h-10 after:w-px after:-translate-y-1/2 after:bg-brand-primary/20" : ""}`}>
                                                <div class="bg-gradient-to-r from-brand-magenta to-brand-pink bg-clip-text font-display text-[36px] font-extrabold leading-none tracking-[-1px] text-transparent md:text-[44px]">
                                                        {stat.value}
                                                </div>
                                                <div class="mt-1.5 text-[13px] text-white/60">{stat.label}</div>
                                        </div>
                                ))}
                        </div>
                </section>

                {/* TWO PATHS */}
                <section class="px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-6xl">
                                <p class="reveal mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        Two Ways We Can Help
                                </p>
                                <h2 class="reveal mb-14 max-w-2xl font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        Choose the path that fits where you are right now.
                                </h2>
                                <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
                                        {twoPathCards.map((card) => (
                                                <article class="reveal group relative overflow-hidden rounded-[24px] border border-brand-primary/20 bg-white/[0.03] p-10 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/40 hover:bg-brand-primary/[0.06]">
                                                        <div class="mb-4 text-4xl">{card.icon}</div>
                                                        <p class="mb-3 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">{card.tag}</p>
                                                        <p class="mb-8 text-base leading-[1.7] text-white/65">{card.body}</p>
                                                        <a
                                                                href={card.href}
                                                                class="inline-flex items-center gap-2 font-display text-[15px] font-semibold text-brand-primary transition hover:text-white"
                                                        >
                                                                {card.cta}
                                                                <span aria-hidden="true">→</span>
                                                        </a>
                                                </article>
                                        ))}
                                </div>
                        </div>
                </section>

                {/* WHO THIS IS FOR */}
                <section class="border-y border-brand-primary/15 px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-6xl">
                                <div class="grid grid-cols-1 gap-16 md:grid-cols-2">
                                        <div class="reveal">
                                                <p class="mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">This Is For You If You Are</p>
                                                <ul class="space-y-4">
                                                        {whoThisIsFor.map((item) => (
                                                                <li class="flex items-start gap-3 text-base leading-[1.7] text-white/70">
                                                                        <span class="mt-1 text-brand-accent">✓</span>
                                                                        {item}
                                                                </li>
                                                        ))}
                                                </ul>
                                        </div>
                                        <div class="reveal">
                                                <p class="mb-4 text-xs font-semibold uppercase tracking-[3px] text-white/40">This May Not Be a Fit If You Are</p>
                                                <ul class="space-y-4">
                                                        {whoThisIsNotFor.map((item) => (
                                                                <li class="flex items-start gap-3 text-base leading-[1.7] text-white/40">
                                                                        <span class="mt-1">—</span>
                                                                        {item}
                                                                </li>
                                                        ))}
                                                </ul>
                                                <p class="mt-8 text-sm italic text-white/40">If this sounds like you, the next step is a simple conversation — not a pitch.</p>
                                        </div>
                                </div>
                        </div>
                </section>

                {/* HOW WE HELP */}
                <section id="how-we-help" class="px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-6xl">
                                <p class="reveal mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        How We Help
                                </p>
                                <h2 class="reveal mb-14 max-w-2xl font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        Advisor-led guidance across every stage of your journey.
                                </h2>
                                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                                        {howWeHelp.map((item, i) => (
                                                <article class="reveal group relative overflow-hidden rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-9 transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary/35 hover:bg-brand-primary/[0.06]">
                                                        <div class="mb-4 font-display text-4xl font-bold text-brand-primary/30">
                                                                {String(i + 1).padStart(2, "0")}
                                                        </div>
                                                        <h3 class="mb-3 font-display text-lg font-bold tracking-[-0.3px] text-white">{item.title}</h3>
                                                        <p class="text-sm leading-[1.7] text-white/60">{item.body}</p>
                                                </article>
                                        ))}
                                </div>
                        </div>
                </section>

                {/* HOW WE ARE DIFFERENT */}
                <section class="border-y border-brand-primary/15 px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-4xl">
                                <p class="reveal mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        How We Are Different
                                </p>
                                <h2 class="reveal mb-14 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        Operator experience, not just advisory credentials.
                                </h2>
                                <ul class="space-y-6">
                                        {differentiators.map((item) => (
                                                <li class="reveal flex items-start gap-4 text-lg leading-[1.7] text-white/70">
                                                        <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-brand-primary"></span>
                                                        {item}
                                                </li>
                                        ))}
                                </ul>
                        </div>
                </section>

                {/* MEET THE ADVISORS */}
                <section class="px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-6xl">
                                <p class="reveal mb-4 text-center text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        Meet the Advisors
                                </p>
                                <h2 class="reveal mb-14 text-center font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        Operators who have been where you are.
                                </h2>
                                <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
                                        {advisors.map((advisor) => (
                                                <article class="reveal group overflow-hidden rounded-[24px] border border-white/10 bg-white/[0.03] transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/40">
                                                        <div class="overflow-hidden bg-brand-primary/10">
                                                                <img
                                                                        src={advisor.photo}
                                                                        alt={advisor.name}
                                                                        loading="lazy"
                                                                        class="aspect-[4/3] w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
                                                                />
                                                        </div>
                                                        <div class="p-8">
                                                                <h3 class="font-display text-2xl font-bold text-white">{advisor.name}</h3>
                                                                <p class="mt-1 text-sm text-brand-accent">{advisor.title}</p>
                                                                <p class="mt-4 text-base leading-[1.7] text-white/65">{advisor.bio}</p>
                                                                <a
                                                                        href={advisor.href}
                                                                        class="mt-6 inline-flex items-center gap-2 font-display text-sm font-semibold text-brand-primary transition hover:text-white"
                                                                >
                                                                        View Full Profile →
                                                                </a>
                                                        </div>
                                                </article>
                                        ))}
                                </div>
                        </div>
                </section>

                {/* TESTIMONIALS */}
                <section class="border-y border-brand-primary/15 px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-6xl">
                                <p class="reveal mb-4 text-center text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        Trusted Guidance. Real Results.
                                </p>
                                <h2 class="reveal mb-14 text-center font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        Hear from business owners who moved forward with confidence.
                                </h2>
                                <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                                        {testimonials.map((t) => (
                                                <article class="reveal rounded-[20px] border border-brand-primary/[0.12] bg-white/[0.03] p-8">
                                                        <blockquote class="text-base leading-[1.8] text-white/70 italic">
                                                                "{t.quote}"
                                                        </blockquote>
                                                        <div class="mt-6 border-t border-white/10 pt-6">
                                                                <p class="font-display font-bold text-white">{t.name}</p>
                                                                <p class="mt-1 text-sm text-brand-accent">{t.title}</p>
                                                        </div>
                                                </article>
                                        ))}
                                </div>

                                {videoTestimonials.length > 0 && (
                                        <>
                                                <div class="reveal mt-12 flex justify-center">
                                                        <button
                                                                type="button"
                                                                data-load-more-testimonials
                                                                aria-expanded="false"
                                                                aria-controls="video-testimonials-grid"
                                                                class="inline-flex items-center justify-center gap-2 rounded-full border border-brand-primary/40 bg-white/[0.03] px-8 py-3 font-display text-sm font-semibold text-white transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-brand-accent/60 hover:bg-brand-primary/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-[#010130]"
                                                        >
                                                                <span data-load-more-label>Load More Testimonials</span>
                                                                <span data-load-more-icon class="transition-transform duration-300" aria-hidden="true">↓</span>
                                                        </button>
                                                </div>

                                                <div
                                                        id="video-testimonials-grid"
                                                        data-video-testimonials
                                                        hidden
                                                        class="reveal-stagger mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5"
                                                >
                                                        {videoTestimonials.map((t, i) => (
                                                                <button
                                                                        type="button"
                                                                        class="group flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-3 text-left transition-all duration-300 ease-out hover:-translate-y-1 hover:border-brand-accent/40 hover:shadow-[0_8px_40px_rgba(15,255,255,0.18)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-[#010130]"
                                                                        data-testimonial-trigger
                                                                        data-testimonial-index={i}
                                                                        aria-label={`Play client testimonial ${i + 1}`}
                                                                >
                                                                        <div class="relative aspect-[9/16] overflow-hidden rounded-xl bg-black">
                                                                                {t.thumbnailUrl ? (
                                                                                        <img
                                                                                                src={t.thumbnailUrl}
                                                                                                alt=""
                                                                                                loading="lazy"
                                                                                                class="h-full w-full object-cover"
                                                                                        />
                                                                                ) : (
                                                                                        <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/30 via-brand-secondary/20 to-brand-magenta/15" aria-hidden="true"></div>
                                                                                )}
                                                                                <span
                                                                                        class="pointer-events-none absolute inset-0 m-auto flex h-12 w-12 items-center justify-center rounded-full bg-white/85 shadow-[0_4px_16px_rgba(0,0,0,0.3)] transition-all duration-300 group-hover:bg-white motion-safe:group-hover:scale-[1.15] sm:h-14 sm:w-14"
                                                                                        aria-hidden="true"
                                                                                >
                                                                                        <svg viewBox="0 0 24 24" fill="currentColor" class="ml-0.5 h-5 w-5 text-brand-secondary sm:h-6 sm:w-6">
                                                                                                <polygon points="6 4 20 12 6 20 6 4" />
                                                                                        </svg>
                                                                                </span>
                                                                        </div>
                                                                </button>
                                                        ))}
                                                </div>
                                        </>
                                )}
                        </div>
                </section>

                {/* HOW IT WORKS */}
                <section class="px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-4xl">
                                <p class="reveal mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        How It Works
                                </p>
                                <h2 class="reveal mb-14 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        From first call to moving forward — four simple steps.
                                </h2>
                                <ol class="space-y-12">
                                        {pathSteps.map((step, i) => (
                                                <li class="reveal grid grid-cols-[auto_1fr] gap-8">
                                                        <div class="font-display text-5xl font-bold text-brand-primary/30">
                                                                {String(i + 1).padStart(2, "0")}
                                                        </div>
                                                        <div>
                                                                <h3 class="font-display text-xl font-bold text-white">{step.title}</h3>
                                                                <p class="mt-3 text-base leading-[1.7] text-white/60">{step.body}</p>
                                                        </div>
                                                </li>
                                        ))}
                                </ol>
                        </div>
                </section>

                {/* FAQ */}
                <section class="border-t border-brand-primary/15 px-6 py-24 md:px-12">
                        <div class="mx-auto max-w-3xl">
                                <p class="reveal mb-4 text-xs font-semibold uppercase tracking-[3px] text-brand-accent">
                                        Common Questions
                                </p>
                                <h2 class="reveal mb-14 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-[1.1] tracking-[-1.5px] text-white">
                                        Questions we get asked most.
                                </h2>
                                <div class="border-t border-white/10">
                                        {faqItems.map((item) => (
                                                <details class="group border-b border-white/10">
                                                        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-6 [&::-webkit-details-marker]:hidden">
                                                                <span class="font-display text-base font-semibold text-white md:text-lg">{item.q}</span>
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0 text-white/40 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
                                                                        <polyline points="6 9 12 15 18 9" />
                                                                </svg>
                                                        </summary>
                                                        <p class="pb-6 pr-9 text-base leading-relaxed text-white/60">{item.a}</p>
                                                </details>
                                        ))}
                                </div>
                        </div>
                </section>

                {/* FINAL CTA */}
                <section class="reveal mx-6 mb-24 overflow-hidden rounded-[28px] bg-gradient-to-br from-brand-secondary to-brand-primary p-20 text-center md:mx-12">
                        <div class="relative">
                                <h2 class="reveal mb-4 font-display text-[clamp(32px,4vw,52px)] font-extrabold leading-tight tracking-[-1.5px] text-white">
                                        Ready to explore your options with zero pressure?
                                </h2>
                                <p class="reveal mb-10 text-base text-white/70 [transition-delay:100ms]">
                                        Book a free 30-minute strategy call. We will discuss your goals, your situation, and whether our advisory is the right fit. No obligation. No pitch.
                                </p>
                                <a
                                        href="/contact"
                                        class="reveal inline-block rounded-full bg-white px-9 py-3.5 font-display text-[15px] font-bold text-brand-secondary transition-all [transition-delay:200ms] hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(0,0,0,0.3)]"
                                >
                                        Book a Strategy Call →
                                </a>
                                <p class="mt-6 text-sm text-white/60">No obligation. No sales pressure. Calls typically last 30 minutes.</p>
                        </div>
                </section>

        </div>

        <TestimonialLightbox testimonials={videoTestimonials} />

        <script>
                // Toggle the hidden video testimonial grid below the written quotes.
                // Re-runs on each astro:page-load so a new button gets wired after view transitions.
                document.addEventListener('astro:page-load', () => {
                        const button = document.querySelector<HTMLButtonElement>('[data-load-more-testimonials]');
                        const grid = document.querySelector<HTMLElement>('[data-video-testimonials]');
                        if (!button || !grid) return;

                        const label = button.querySelector<HTMLElement>('[data-load-more-label]');
                        const icon = button.querySelector<HTMLElement>('[data-load-more-icon]');

                        button.addEventListener('click', () => {
                                const willOpen = grid.hasAttribute('hidden');
                                if (willOpen) {
                                        grid.removeAttribute('hidden');
                                        button.setAttribute('aria-expanded', 'true');
                                        if (label) label.textContent = 'Show Fewer Testimonials';
                                        if (icon) icon.style.transform = 'rotate(180deg)';
                                } else {
                                        grid.setAttribute('hidden', '');
                                        button.setAttribute('aria-expanded', 'false');
                                        if (label) label.textContent = 'Load More Testimonials';
                                        if (icon) icon.style.transform = '';
                                }
                        });
                });
        </script>
</Layout>
