<section class="relative flex min-h-[100vh] flex-col items-center justify-center overflow-hidden px-6 pb-20 pt-4 text-center md:px-12 md:pt-8 mx-auto w-full">
	<div class="orb orb-1" aria-hidden="true"></div>
	<div class="orb orb-2" aria-hidden="true"></div>
	<div class="orb orb-3" aria-hidden="true"></div>
	<div class="grid-overlay" aria-hidden="true"></div>

	<div class="reveal relative z-10 inline-flex items-center gap-2 rounded-full border border-brand-primary/30 bg-brand-primary/[0.12] py-1.5 pl-2.5 pr-4 text-[13px] font-medium text-brand-accent">
		<span class="animate-pulse-dot h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
		Trusted by 75+ aesthetic &amp; wellness brands
	</div>

	<h1 class="reveal relative z-10 mt-8 whitespace-nowrap font-display font-extrabold leading-[1.05] tracking-[-0.04em] text-[clamp(35px,7.7vw,97px)] text-white [transition-delay:100ms]">
		Get More
		{/*
		  Outer wrapper: inline-block with NO overflow:hidden so its baseline matches
		  surrounding text (taken from the invisible "Bookings" sizer's text baseline).
		  Inner mask: absolute over the wrapper, overflow:hidden, holds the scrolling
		  word list. This split keeps the surrounding "Get More" baseline locked while
		  still clipping the off-screen words.
		*/}
		<span class="relative inline-block align-baseline leading-none">
			<span class="invisible" aria-hidden="true">Bookings</span>
			<span class="absolute inset-0 overflow-hidden leading-none">
				<span
					data-rotating-words
					class="absolute left-0 top-0 leading-none will-change-transform transition-transform duration-500 ease-out motion-reduce:transition-none"
				>
					<span class="block bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">Bookings</span>
					<span class="block bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">Revenue</span>
					<span class="block bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">Results</span>
					<span class="block bg-gradient-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">Bookings</span>
				</span>
			</span>
			<span class="sr-only" aria-live="polite" data-rotating-announce>Bookings</span>
		</span>
	</h1>

	<p class="reveal relative z-10 mt-7 max-w-xl text-lg font-normal leading-relaxed text-white/60 [transition-delay:200ms]">
		The Growth Now Method™ helps aesthetic and wellness businesses fill their calendars, grow their revenue, and remove the guesswork — without the hype.
	</p>

	<div class="reveal relative z-10 mt-12 flex items-center gap-4 [transition-delay:300ms]">
		<a
			href="/contact"
			class="rounded-full bg-brand-primary px-8 py-3.5 font-display text-[15px] font-semibold text-white shadow-[0_0_32px_rgba(138, 26, 255,0.35)] transition-all hover:-translate-y-0.5 hover:bg-brand-secondary hover:shadow-[0_8px_40px_rgba(138, 26, 255,0.5)]"
		>
			Book a Demo
		</a>
		<a
			href="#services"
			class="group flex items-center gap-2 font-display text-[15px] font-medium text-white/70 transition hover:text-white"
		>
			See how it works
			<span class="flex h-8 w-8 items-center justify-center rounded-full border border-white/20 text-sm transition group-hover:border-white/40">→</span>
		</a>
	</div>
</section>

<script>
	let intervalId: number | null = null;

	function startRotator() {
		const list = document.querySelector<HTMLElement>('[data-rotating-words]');
		const announcer = document.querySelector<HTMLElement>('[data-rotating-announce]');
		if (!list) return;

		// Reset any leftover transform from a previous mount before starting.
		list.style.transition = 'none';
		list.style.transform = 'translateY(0)';
		void list.offsetHeight;
		list.style.transition = '';

		const words = ['Bookings', 'Revenue', 'Results'];
		const TOTAL = words.length;
		let index = 0;

		intervalId = window.setInterval(() => {
			index += 1;
			list.style.transform = `translateY(-${index}em)`;
			if (announcer) {
				announcer.textContent = words[index % TOTAL];
			}

			// Seamless loop: after the duplicate "Bookings" (position 3) finishes
			// sliding into view, snap back to position 0 silently. Both positions
			// show "Bookings" so the user sees no jump.
			if (index === TOTAL) {
				setTimeout(() => {
					list.style.transition = 'none';
					list.style.transform = 'translateY(0)';
					void list.offsetHeight;
					list.style.transition = '';
					index = 0;
				}, 500);
			}
		}, 2400);
	}

	function stopRotator() {
		if (intervalId !== null) {
			clearInterval(intervalId);
			intervalId = null;
		}
	}

	document.addEventListener('astro:page-load', startRotator);
	document.addEventListener('astro:before-swap', stopRotator);
</script>
