---
// TODO: confirm real numbers with client before launch
const stats = [
	{ value: '4X+', label: 'Average Client ROI' },
	{ value: '500+', label: 'Locations Serviced' },
	{ value: '$50M', label: 'Ad Spend Managed' },
	{ value: '$200M', label: 'Client Revenue Generated' },
];
---

<section class="bg-ink py-16 md:py-20">
	<div class="mx-auto max-w-6xl px-6">
		<div class="max-w-2xl">
			<p class="text-sm font-semibold uppercase tracking-wider text-white/60">
				Trusted by over 500+ aesthetic &amp; wellness locations
			</p>
			<h3 class="mt-4 font-display text-2xl font-semibold leading-tight text-white md:text-3xl">
				Real numbers. Real operators. Real results.
			</h3>
		</div>

		<div class="mt-12 grid grid-cols-2 gap-8 md:grid-cols-4">
			{stats.map((stat) => (
				<div>
					<div class="font-display text-5xl font-bold text-brand-primary md:text-6xl">
						{stat.value}
					</div>
					<div class="mt-2 text-sm font-medium leading-snug text-white/80 md:text-base">
						{stat.label}
					</div>
				</div>
			))}
		</div>
	</div>
</section>
