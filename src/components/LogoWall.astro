---
import { logos } from '../data/logos';

interface Props {
	showTagline?: boolean;
}
const { showTagline = true } = Astro.props;

// Split into 3 roughly-equal rows. With 32 logos: 11 / 11 / 10.
const rowSize = Math.ceil(logos.length / 3);
const row1 = logos.slice(0, rowSize);
const row2 = logos.slice(rowSize, rowSize * 2);
const row3 = logos.slice(rowSize * 2);
const rows = [row1, row2, row3];
---

<section
	class="logo-wall reveal py-12 md:py-16"
	aria-label="Trusted by 500+ aesthetic and wellness businesses"
>
	{showTagline && (
		<p class="mb-8 text-center text-xs font-medium uppercase tracking-[3px] text-brand-primary/80">
			Trusted by 500+ aesthetic &amp; wellness businesses
		</p>
	)}

	<div class="logo-wall-stack">
		{rows.map((rowLogos, rowIdx) => (
			<div class="logo-wall-container">
				<div class={`logo-wall-track row-${rowIdx + 1}`}>
					{rowLogos.map((file) => (
						<span class="logo-item">
							<img
								src={`/logos/${file}`}
								alt=""
								loading="lazy"
								decoding="async"
								height="60"
								class={file.endsWith('.svg') ? 'logo-svg' : 'logo-png'}
							/>
						</span>
					))}
					{rowLogos.map((file) => (
						<span class="logo-item" aria-hidden="true">
							<img
								src={`/logos/${file}`}
								alt=""
								loading="lazy"
								decoding="async"
								height="60"
								class={file.endsWith('.svg') ? 'logo-svg' : 'logo-png'}
							/>
						</span>
					))}
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.logo-wall-stack {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		width: 100%;
	}

	.logo-wall-container {
		overflow: hidden;
		width: 100%;
		mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
		-webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
	}

	.logo-wall-track {
		display: flex;
		align-items: center;
		width: max-content;
		opacity: 0.7;
		will-change: transform;
	}

	/* Per-item trailing margin instead of parent flex `gap`. With `gap` the
	   2× duplicated set has one fewer gap than slot, so translateX(-50%)
	   lands half-a-gap short of the duplicate's first item and the snap-back
	   produces a visible jump. With margin-right each slot is exactly
	   item + 48px including the last one — so -50% lands precisely on the
	   duplicate's first slot, making the loop seamless. */
	.logo-item {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		margin-right: 48px;
	}

	.logo-item img {
		display: block;
		height: 60px;
		width: auto;
		min-width: 80px; /* fallback footprint for broken images during placeholder phase */
	}

	@media (max-width: 768px) {
		.logo-item img { height: 44px; }
	}

	/* SVGs forced to pure white silhouette. PNGs assumed pre-processed. */
	.logo-svg {
		filter: brightness(0) invert(1);
	}

	/* Slowed by 15% from the previous 75s → 86.25s. */
	.logo-wall-track.row-1 {
		animation: scroll-logos-left 86.25s linear infinite;
	}

	.logo-wall-track.row-2 {
		animation: scroll-logos-right 86.25s linear infinite;
	}

	.logo-wall-track.row-3 {
		animation: scroll-logos-left 86.25s linear infinite;
	}

	@keyframes scroll-logos-left {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	@keyframes scroll-logos-right {
		from { transform: translateX(-50%); }
		to { transform: translateX(0); }
	}

	.logo-wall-container:hover .logo-wall-track {
		animation-play-state: paused;
	}

	@media (prefers-reduced-motion: reduce) {
		.logo-wall-track {
			animation: none;
		}
	}
</style>
