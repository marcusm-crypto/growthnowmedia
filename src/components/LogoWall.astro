---
import { logos } from '../data/logos';

interface Props {
	showTagline?: boolean;
}
const { showTagline = true } = Astro.props;
---

<section
	class="logo-wall reveal py-12 md:py-16"
	aria-label="Trusted by 500+ aesthetic and wellness businesses"
>
	{showTagline && (
		<p class="mb-8 text-center text-xs font-medium uppercase tracking-[3px] text-brand-primary/80">
			Trusted by 500+ aesthetic &amp; wellness businesses
		</p>
	)}

	<div class="marquee-mask space-y-6">
		<div class="marquee-track marquee-left">
			{logos.map((file) => (
				<span class="marquee-item">
					<img
						src={`/logos/${file}`}
						alt=""
						loading="lazy"
						decoding="async"
						height="60"
						class={file.endsWith('.svg') ? 'logo-svg' : 'logo-png'}
					/>
				</span>
			))}
			{logos.map((file) => (
				<span class="marquee-item" aria-hidden="true">
					<img
						src={`/logos/${file}`}
						alt=""
						loading="lazy"
						decoding="async"
						height="60"
						class={file.endsWith('.svg') ? 'logo-svg' : 'logo-png'}
					/>
				</span>
			))}
		</div>

		<div class="marquee-track marquee-right">
			{logos.map((file) => (
				<span class="marquee-item">
					<img
						src={`/logos/${file}`}
						alt=""
						loading="lazy"
						decoding="async"
						height="60"
						class={file.endsWith('.svg') ? 'logo-svg' : 'logo-png'}
					/>
				</span>
			))}
			{logos.map((file) => (
				<span class="marquee-item" aria-hidden="true">
					<img
						src={`/logos/${file}`}
						alt=""
						loading="lazy"
						decoding="async"
						height="60"
						class={file.endsWith('.svg') ? 'logo-svg' : 'logo-png'}
					/>
				</span>
			))}
		</div>
	</div>
</section>

<style>
	.marquee-mask {
		overflow: hidden;
		mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
		-webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
	}

	.marquee-track {
		display: flex;
		align-items: center;
		width: max-content;
		opacity: 0.7;
	}

	.marquee-left {
		animation: marquee-scroll-left 75s linear infinite;
	}

	.marquee-right {
		animation: marquee-scroll-right 75s linear infinite;
	}

	.marquee-item {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		/* Trailing margin instead of flex `gap`: each item's slot is item+64px,
		   so the track of 64 items has width 64·(W+64). translateX(-50%) lands
		   exactly on item33's left edge, making the loop seamless. With `gap`
		   the loop landed half-a-gap short and the snap-back showed a 32px
		   shift. */
		margin-right: 64px;
	}

	@media (max-width: 768px) {
		.marquee-item { margin-right: 48px; }
	}

	.marquee-item img {
		display: block;
		height: 60px;
		width: auto;
		min-width: 80px; /* fallback footprint for broken images during placeholder phase */
	}

	@media (max-width: 768px) {
		.marquee-item img { height: 48px; }
	}

	/* SVGs forced to pure white silhouette. PNGs assumed pre-processed. */
	.logo-svg {
		filter: brightness(0) invert(1);
	}

	@keyframes marquee-scroll-left {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	@keyframes marquee-scroll-right {
		from { transform: translateX(-50%); }
		to { transform: translateX(0); }
	}

	.marquee-mask:hover .marquee-left,
	.marquee-mask:hover .marquee-right {
		animation-play-state: paused;
	}

	@media (prefers-reduced-motion: reduce) {
		.marquee-left,
		.marquee-right {
			animation-play-state: paused;
		}
	}
</style>
